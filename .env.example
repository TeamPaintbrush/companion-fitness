# Copy this file to .env and fill in the values
# .env is gitignored — never commit real values

# Your API Gateway URL (output by backend/setup.js)
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com

# Base path for GitHub Pages (e.g. /companion-fitness/)
# Leave as / for local dev or a custom domain
VITE_BASE_URL=/
